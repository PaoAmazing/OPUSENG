<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="description" content="Portfólio de projetos - OPUS Engenharia. Conheça nossos trabalhos em projetos mecânicos, laudos técnicos, NR12 e consultoria.">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Portfólio - OPUS Engenharia</title>

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-4EW3SD16RP"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-4EW3SD16RP');

    // Event snippet for Visualização de pag conversion page
    gtag('event', 'conversion', {
      'send_to': 'AW-17012385238/Portfolio-view',
      'value': 1.0,
      'currency': 'BRL'
    });
    gtag('event', 'conversion', {'send_to': 'AW-17012385238/YOtDCP2i8NYaENbLkbA_'});
    gtag('config', 'AW-17012385238');
  </script>

  <meta property="og:title" content="Portfólio - OPUS Engenharia">
  <meta property="og:description" content="Engenharia com excelência: projetos, laudos, NR12 e mais.">
  <meta property="og:image" content="https://opusmec.com.br/img/logo.png">
  <meta property="og:url" content="https://opusmec.com.br/portfolio">
  <meta property="og:type" content="website">

  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/header.css" />
  <link rel="stylesheet" href="/css/footer.css" />
  <link rel="stylesheet" href="/css/portfolio.css" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <script src="https://unpkg.com/lucide@latest"></script>
</head>

<body>
  <!-- Header -->
  <header>
    <div class="container">
      <div class="header-content">
        <a href="/" class="logo">
          <img src="/img/logo.png" alt="Logo OPUS" class="logo-img">
          OPUS <span>Engenharia</span>
        </a>
        <nav>
          <ul>
            <li><a href="/">Início</a></li>
            <li><a href="/servicos">Serviços</a></li>
            <li><a href="/sobre">Sobre</a></li>
            <li><a href="/portfolio" class="active">Portfólio</a></li>
            <li><a href="/contato">Contato</a></li>
          </ul>
        </nav>
      </div>
    </div>
  </header>

  <%- include('partials/whatsapp-float') %>

  <!-- Main -->
  <main class="portfolio-page">
    <!-- Page Header -->
    <section class="page-header">
      <div class="hero-overlay"></div>
      <div class="container">
        <h1>Nosso Portfólio</h1>
        <p>Conheça os projetos que realizamos com excelência e dedicação</p>
      </div>
    </section>

    <!-- Portfolio Grid -->
    <section class="portfolio-content">
      <div class="container">
        <div class="portfolio-grid">
          <% projects.forEach(project => { %>
            <div class="portfolio-card">
              <div class="portfolio-image">
                <img src="/img/<%= project.image %>" alt="<%= project.name %>" />
              </div>
              <div class="portfolio-info">
                <h3><%= project.name %></h3>
                <p class="client"><strong>Cliente:</strong> <%= project.client %></p>
                <p class="description"><%= project.description %></p>
                <a href="/contato" class="btn btn-primary">Solicitar Serviço Semelhante</a>
              </div>
            </div>
          <% }); %>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
      <div class="container">
        <h2>Interessado em Trabalhar Conosco?</h2>
        <p>Temos uma equipe pronta para transformar suas ideias em soluções eficientes.</p>
        <a href="/contato" class="btn btn-primary">Entre em Contato</a>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer>
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col">
          <h3>OPUS Engenharia</h3>
          <p>Soluções em engenharia com excelência técnica e compromisso com a qualidade.</p>
        </div>
        <div class="footer-col">
          <h4>Serviços</h4>
          <ul>
            <li><a href="/contato">PMOC</a></li>
            <li><a href="/contato">Projetos Mecânicos</a></li>
            <li><a href="/contato">Laudos Técnicos</a></li>
            <li><a href="/contato">NR12</a></li>
            <li><a href="/contato">Consultoria</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Links Úteis</h4>
          <ul>
            <li><a href="/sobre">Sobre Nós</a></li>
            <li><a href="/porfolio">Portfólio</a></li>
            <li><a href="/contato">Contato</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Contato</h4>
          <ul class="contact-info">
            <li>(61) 9553-3123</li>
            <li>opusengmec@gmail.com</li>
            <li>Brasília, DF</li>
          </ul>
        </div>
      </div>
      <h4>Redes Sociais</h4>
      <div class="social-buttons">
        <a href="https://wa.me/5561995533123?text=Olá%2C+gostaria+de+fazer+um+orçamento+com+a+OPUS+Engenharia"
          target="_blank"
          aria-label="WhatsApp"
          class="social-icon whatsapp">
          <i data-lucide="message-circle"></i>
        </a>
        <a href="https://www.instagram.com/opusengenharia61/"
          target="_blank"
          aria-label="Instagram"
          class="social-icon instagram">
          <i data-lucide="instagram"></i>
        </a>
      </div>
      <div class="copyright">
        <p>&copy; 2025 OPUS Engenharia. Todos os direitos reservados.</p>
      </div>
    </div>
  </footer>

  <script>
    lucide.createIcons();
  </script>
</body>
</html>
