<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Administracao | OPUS Engenharia</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/painel.css" />
  <script src="https://unpkg.com/lucide@latest"></script>
  <style>
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 20px;
      margin-bottom: 40px;
    }

    .stat-card {
      background: white;
      padding: 25px;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      display: flex;
      align-items: center;
      gap: 20px;
      border-left: 4px solid #3498db;
    }

    .stat-icon {
      font-size: 36px;
    }

    .stat-content h3 {
      margin: 0 0 8px 0;
      color: #666;
      font-size: 14px;
    }

    .stat-value {
      margin: 0;
      color: #2c3e50;
      font-size: 28px;
      font-weight: 700;
    }

    .section-card {
      background: white;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      margin-bottom: 30px;
      overflow: hidden;
    }

    .section-header {
      background: #f8f9fa;
      padding: 20px 30px;
      border-bottom: 1px solid #ecf0f1;
    }

    .section-header h2 {
      margin: 0;
      color: #2c3e50;
      font-size: 18px;
    }

    .section-body {
      padding: 30px;
    }

    .chart-container {
      padding: 20px 0;
    }

    .status-distribution {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .status-item {
      display: flex;
      align-items: center;
      gap: 20px;
    }

    .status-bar {
      flex: 1;
      height: 30px;
      background: #ecf0f1;
      border-radius: 15px;
      overflow: hidden;
    }

    .status-fill {
      height: 100%;
      transition: width 0.3s;
    }

    .status-fill.status-pendente {
      background: #ffc107;
    }

    .status-fill.status-em_andamento {
      background: #17a2b8;
    }

    .status-fill.status-concluido {
      background: #28a745;
    }

    .status-fill.status-cancelado {
      background: #dc3545;
    }

    .status-label {
      min-width: 150px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .status-label span {
      color: #666;
      font-size: 14px;
    }

    .status-label strong {
      color: #2c3e50;
      font-size: 18px;
    }

    .system-info {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 30px;
    }

    .info-item {
      border-bottom: 1px solid #ecf0f1;
      padding-bottom: 15px;
    }

    .info-item:last-child {
      border-bottom: none;
    }

    .info-item label {
      display: block;
      font-weight: 600;
      color: #666;
      font-size: 12px;
      text-transform: uppercase;
      margin-bottom: 5px;
    }

    .info-item p {
      margin: 0;
      color: #2c3e50;
      font-size: 16px;
    }

    .actions-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 15px;
    }

    .action-btn {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      border: none;
      padding: 30px 20px;
      border-radius: 8px;
      cursor: pointer;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
      transition: all 0.3s;
      font-weight: 600;
    }

    .action-btn:hover {
      transform: translateY(-5px);
      box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
    }

    .action-icon {
      font-size: 28px;
    }

    .action-name {
      font-size: 14px;
    }

    @media (max-width: 768px) {
      .sidebar {
        display: none;
      }

      .stats-grid {
        grid-template-columns: 1fr;
      }

      .actions-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .status-item {
        flex-direction: column;
        align-items: flex-start;
      }

      .status-label {
        width: 100%;
      }
    }
  </style>
</head>

<body>
  <aside class="sidebar">
    <a href="/" class="sidebar-brand">
      <img src="/img/logo.png" alt="Logo OPUS" />
      <span class="sidebar-brand-text">OPUS <em>Engenharia</em></span>
    </a>

    <div class="sidebar-section">
      <p class="sidebar-section-label">Menu</p>
      <a href="/colaborador/dashboard" class="nav-link">
        <i data-lucide="layout-dashboard"></i> Dashboard
      </a>
      <a href="/colaborador/clientes" class="nav-link">
        <i data-lucide="users"></i> Clientes
      </a>
      <a href="/colaborador/admin" class="nav-link active">
        <i data-lucide="settings-2"></i> Administracao
      </a>
      <a href="/colaborador/perfil" class="nav-link">
        <i data-lucide="user"></i> Meu Perfil
      </a>
    </div>

    <div class="sidebar-spacer"></div>

    <div class="sidebar-footer">
      <a href="/logout" class="nav-link logout">
        <i data-lucide="log-out"></i> Sair
      </a>
    </div>
  </aside>

  <div class="main-content">
    <header class="topbar">
      <span class="topbar-title">Administracao do Sistema</span>
      <div class="topbar-user">
        <div class="user-avatar">
          <%= usuario.nome.charAt(0).toUpperCase() %>
        </div>
        <div class="user-details">
          <span class="user-name"><%= usuario.nome %></span>
          <span class="user-role"><%= usuario.tipo === 'admin' ? 'Administrador' : 'Colaborador' %></span>
        </div>
      </div>
    </header>

    <main class="page-content">
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-icon">📦</div>
          <div class="stat-content">
            <h3>Servicos Totais</h3>
            <p class="stat-value"><%= estatisticas.totalServicos %></p>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon">👥</div>
          <div class="stat-content">
            <h3>Clientes</h3>
            <p class="stat-value"><%= estatisticas.totalClientes %></p>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon">🤝</div>
          <div class="stat-content">
            <h3>Colaboradores</h3>
            <p class="stat-value"><%= estatisticas.totalColaboradores %></p>
          </div>
        </div>
      </div>

      <% if (isAdmin) { %>
        <div class="section-card">
          <div class="section-header">
            <h2>Gerenciar Usuarios</h2>
          </div>
          <div class="section-body">
            <% if (usuarios.length === 0) { %>
              <div class="empty-state">
                <p>Nenhum usuario encontrado.</p>
              </div>
            <% } else { %>
              <div class="table-wrap">
                <table>
                  <thead>
                    <tr>
                      <th>Nome</th>
                      <th>Email</th>
                      <th>Perfil</th>
                      <th>Status</th>
                      <th>Criado em</th>
                      <th>Acao</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% usuarios.forEach(user => { %>
                      <tr>
                        <td style="font-weight:600;color:var(--gray-900)"><%= user.nome %></td>
                        <td><%= user.email %></td>
                        <td>
                          <select name="tipo" class="filter-select" style="min-width:160px;" form="user-form-<%= user.id %>">
                            <option value="cliente" <%= user.tipo === 'cliente' ? 'selected' : '' %>>Cliente</option>
                            <option value="colaborador" <%= user.tipo === 'colaborador' ? 'selected' : '' %>>Colaborador</option>
                            <option value="admin" <%= user.tipo === 'admin' ? 'selected' : '' %>>Administrador</option>
                          </select>
                        </td>
                        <td>
                          <span class="badge <%= user.ativo ? 'badge-concluido' : 'badge-cancelado' %>">
                            <%= user.ativo ? 'Ativo' : 'Inativo' %>
                          </span>
                        </td>
                        <td style="color:var(--gray-400);font-size:0.8125rem">
                          <%= new Date(user.data_criacao).toLocaleDateString('pt-BR') %>
                        </td>
                        <td>
                          <form id="user-form-<%= user.id %>" action="/colaborador/admin/usuarios/<%= user.id %>/tipo" method="POST">
                            <button type="submit" class="btn btn-primary btn-sm">
                              <i data-lucide="save"></i> Salvar
                            </button>
                          </form>
                        </td>
                      </tr>
                    <% }); %>
                  </tbody>
                </table>
              </div>
            <% } %>
          </div>
        </div>
      <% } %>

      <div class="section-card">
        <div class="section-header">
          <h2>Distribuicao de Servicos por Status</h2>
        </div>
        <div class="section-body">
          <div class="chart-container">
            <div class="status-distribution">
              <div class="status-item">
                <div class="status-bar">
                  <div class="status-fill status-pendente" data-percent="<%= estatisticas.servicosPorStatus.pendente ? (estatisticas.servicosPorStatus.pendente / estatisticas.totalServicos * 100) : 0 %>"></div>
                </div>
                <div class="status-label">
                  <span>Pendentes:</span>
                  <strong><%= estatisticas.servicosPorStatus.pendente || 0 %></strong>
                </div>
              </div>

              <div class="status-item">
                <div class="status-bar">
                  <div class="status-fill status-em_andamento" data-percent="<%= estatisticas.servicosPorStatus.em_andamento ? (estatisticas.servicosPorStatus.em_andamento / estatisticas.totalServicos * 100) : 0 %>"></div>
                </div>
                <div class="status-label">
                  <span>Em Andamento:</span>
                  <strong><%= estatisticas.servicosPorStatus.em_andamento || 0 %></strong>
                </div>
              </div>

              <div class="status-item">
                <div class="status-bar">
                  <div class="status-fill status-concluido" data-percent="<%= estatisticas.servicosPorStatus.concluido ? (estatisticas.servicosPorStatus.concluido / estatisticas.totalServicos * 100) : 0 %>"></div>
                </div>
                <div class="status-label">
                  <span>Concluidos:</span>
                  <strong><%= estatisticas.servicosPorStatus.concluido || 0 %></strong>
                </div>
              </div>

              <div class="status-item">
                <div class="status-bar">
                  <div class="status-fill status-cancelado" data-percent="<%= estatisticas.servicosPorStatus.cancelado ? (estatisticas.servicosPorStatus.cancelado / estatisticas.totalServicos * 100) : 0 %>"></div>
                </div>
                <div class="status-label">
                  <span>Cancelados:</span>
                  <strong><%= estatisticas.servicosPorStatus.cancelado || 0 %></strong>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="section-card">
        <div class="section-header">
          <h2>Informacoes do Sistema</h2>
        </div>
        <div class="section-body">
          <div class="system-info">
            <div class="info-item">
              <label>Versao:</label>
              <p>1.0.0</p>
            </div>
            <div class="info-item">
              <label>Banco de Dados:</label>
              <p>SQLite 3</p>
            </div>
            <div class="info-item">
              <label>Ambiente:</label>
              <p><%= process.env.NODE_ENV || 'desenvolvimento' %></p>
            </div>
            <div class="info-item">
              <label>Node.js:</label>
              <p><%= process.version %></p>
            </div>
          </div>
        </div>
      </div>

      <div class="section-card">
        <div class="section-header">
          <h2>Acoes Administrativas</h2>
        </div>
        <div class="section-body">
          <div class="actions-grid">
            <button class="action-btn" onclick="manutencao()">
              <span class="action-icon">🔧</span>
              <span class="action-name">Manutencao</span>
            </button>
            <button class="action-btn" onclick="backup()">
              <span class="action-icon">💾</span>
              <span class="action-name">Backup</span>
            </button>
            <button class="action-btn" onclick="logs()">
              <span class="action-icon">📋</span>
              <span class="action-name">Logs</span>
            </button>
            <button class="action-btn" onclick="exportar()">
              <span class="action-icon">📥</span>
              <span class="action-name">Exportar</span>
            </button>
          </div>
        </div>
      </div>
    </main>
  </div>

  <script>
    lucide.createIcons();

    document.querySelectorAll('.status-fill').forEach((bar) => {
      const value = Number(bar.dataset.percent || 0);
      bar.style.width = `${Math.min(100, Math.max(0, value))}%`;
    });

    function manutencao() {
      alert('Funcionalidade de manutencao sera implementada em breve');
    }

    function backup() {
      alert('Funcionalidade de backup sera implementada em breve');
    }

    function logs() {
      alert('Funcionalidade de visualizacao de logs sera implementada em breve');
    }

    function exportar() {
      alert('Funcionalidade de exportacao sera implementada em breve');
    }
  </script>
</body>

</html>
