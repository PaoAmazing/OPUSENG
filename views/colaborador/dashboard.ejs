<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Painel Colaborador | OPUS Engenharia</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/painel.css" />
  <script src="https://unpkg.com/lucide@latest"></script>
</head>

<body>

  <!-- ── Sidebar ── -->
  <aside class="sidebar">
    <a href="/" class="sidebar-brand">
      <img src="/img/logo.png" alt="Logo OPUS" />
      <span class="sidebar-brand-text">OPUS <em>Engenharia</em></span>
    </a>

    <div class="sidebar-section">
      <p class="sidebar-section-label">Menu</p>
      <a href="/colaborador/dashboard" class="nav-link active">
        <i data-lucide="layout-dashboard"></i> Dashboard
      </a>
      <a href="/colaborador/clientes" class="nav-link">
        <i data-lucide="users"></i> Clientes
      </a>
      <a href="/colaborador/admin" class="nav-link">
        <i data-lucide="settings-2"></i> Administração
      </a>
      <a href="/colaborador/perfil" class="nav-link">
        <i data-lucide="user"></i> Meu Perfil
      </a>
    </div>

    <div class="sidebar-spacer"></div>

    <div class="sidebar-footer">
      <a href="/logout" class="nav-link logout">
        <i data-lucide="log-out"></i> Sair
      </a>
    </div>
  </aside>

  <!-- ── Main ── -->
  <div class="main-content">

    <!-- Topbar -->
    <header class="topbar">
      <span class="topbar-title">Painel do Colaborador</span>
      <div class="topbar-user">
        <div class="user-avatar">
          <%= usuario.nome.charAt(0).toUpperCase() %>
        </div>
        <div class="user-details">
          <span class="user-name">
            <%= usuario.nome %>
          </span>
          <span class="user-role"><%= usuario.tipo === 'admin' ? 'Administrador' : 'Colaborador' %></span>
        </div>
      </div>
    </header>

    <!-- Conteúdo -->
    <main class="page-content">

      <!-- Stat Cards -->
      <div class="stats-grid">
        <div class="stat-card total">
          <div class="stat-icon"><i data-lucide="package"></i></div>
          <div>
            <div class="stat-value">
              <%= contadores.total %>
            </div>
            <div class="stat-label">Total de Serviços</div>
          </div>
        </div>
        <div class="stat-card pending">
          <div class="stat-icon"><i data-lucide="clock"></i></div>
          <div>
            <div class="stat-value">
              <%= contadores.pendente %>
            </div>
            <div class="stat-label">Pendentes</div>
          </div>
        </div>
        <div class="stat-card ongoing">
          <div class="stat-icon"><i data-lucide="refresh-cw"></i></div>
          <div>
            <div class="stat-value">
              <%= contadores.em_andamento %>
            </div>
            <div class="stat-label">Em Andamento</div>
          </div>
        </div>
        <div class="stat-card done">
          <div class="stat-icon"><i data-lucide="check-circle-2"></i></div>
          <div>
            <div class="stat-value">
              <%= contadores.concluido %>
            </div>
            <div class="stat-label">Concluídos</div>
          </div>
        </div>
      </div>

      <!-- Tabela de Serviços -->
      <div class="card">
        <div class="card-header">
          <h2 class="card-title">Serviços em Gerenciamento</h2>
        </div>

        <!-- Filtros -->
        <div class="filters-bar">
          <select id="filterStatus" class="filter-select">
            <option value="">Todos os Status</option>
            <option value="pendente">Pendentes</option>
            <option value="em_andamento">Em Andamento</option>
            <option value="concluido">Concluídos</option>
            <option value="cancelado">Cancelados</option>
          </select>
        </div>

        <% if (servicos.length===0) { %>
          <div class="empty-state">
            <i data-lucide="inbox"></i>
            <p>Nenhum serviço disponível.</p>
          </div>
          <% } else { %>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Cliente</th>
                    <th>Serviço</th>
                    <th>Status</th>
                    <th>Prioridade</th>
                    <th>Data</th>
                    <th>Ação</th>
                  </tr>
                </thead>
                <tbody>
                  <% servicos.forEach(servico=> { %>
                    <tr class="service-row" data-status="<%= servico.status %>">
                      <td style="font-weight:600;color:var(--gray-900)">
                        <%= servico.cliente_nome %>
                      </td>
                      <td>
                        <%= servico.titulo %>
                      </td>
                      <td>
                        <span class="badge badge-<%= servico.status %>">
                          <%= servico.status.replace(/_/g,' ').replace(/\b\w/g,c=>c.toUpperCase()) %>
                      </span>
                    </td>
                    <td>
                      <span class="badge badge-prioridade-<%= servico.prioridade %>">
                        <%= servico.prioridade.toUpperCase() %>
                      </span>
                    </td>
                    <td style="color:var(--gray-400);font-size:0.8125rem">
                      <%= new Date(servico.data_criacao).toLocaleDateString('pt-BR') %>
                      </td>
                      <td>
                        <a href="/colaborador/servico/<%= servico.id %>" class="btn btn-primary btn-sm">
                          <i data-lucide="pencil"></i> Gerenciar
                        </a>
                      </td>
                    </tr>
                    <% }); %>
                </tbody>
              </table>
            </div>
            <% } %>
      </div>

    </main>
  </div>

  <script>
    lucide.createIcons();

    document.getElementById('filterStatus').addEventListener('change', function () {
      const v = this.value;
      document.querySelectorAll('.service-row').forEach(row => {
        row.style.display = (!v || row.dataset.status === v) ? '' : 'none';
      });
    });
  </script>
</body>

</html>