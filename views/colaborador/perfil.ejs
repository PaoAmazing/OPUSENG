<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Meu Perfil | OPUS Engenharia</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/painel.css" />
  <script src="https://unpkg.com/lucide@latest"></script>
  <style>
    .perfil-card {
      background: white;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      padding: 40px;
      margin-bottom: 30px;
      display: flex;
      align-items: flex-start;
      gap: 40px;
    }

    .perfil-avatar {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100px;
      height: 100px;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      border-radius: 50%;
      flex-shrink: 0;
    }

    .avatar-icon {
      font-size: 48px;
    }

    .perfil-content {
      flex: 1;
    }

    .perfil-content h2 {
      margin: 0 0 5px 0;
      color: #2c3e50;
      font-size: 28px;
    }

    .perfil-type {
      margin: 0 0 20px 0;
      color: #667eea;
      font-weight: 600;
    }

    .perfil-form {
      margin-top: 20px;
    }

    .form-group {
      margin-bottom: 25px;
    }

    .form-group label {
      display: block;
      margin-bottom: 8px;
      color: #333;
      font-weight: 600;
      font-size: 14px;
    }

    .form-control {
      width: 100%;
      padding: 10px 12px;
      border: 1px solid #ddd;
      border-radius: 5px;
      font-size: 14px;
      transition: border-color 0.3s;
      box-sizing: border-box;
    }

    .form-control:focus {
      outline: none;
      border-color: #667eea;
      box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }

    .form-control:disabled {
      background: #f5f5f5;
      color: #999;
    }

    .form-text {
      display: block;
      margin-top: 5px;
      font-size: 12px;
      color: #666;
    }

    .form-info {
      background: #f8f9fa;
      padding: 15px;
      border-radius: 5px;
      margin-bottom: 20px;
    }

    .form-info p {
      margin: 8px 0;
      color: #555;
      font-size: 14px;
    }

    .form-info strong {
      color: #2c3e50;
    }

    .status-badge {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
    }

    .status-ativo {
      background: #d1e7dd;
      color: #0f5132;
    }

    .status-inativo {
      background: #f8d7da;
      color: #842029;
    }

    .form-actions {
      display: flex;
      gap: 10px;
      margin-bottom: 20px;
    }

    .btn {
      padding: 10px 20px;
      border: none;
      border-radius: 5px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s;
    }

    .btn-primary {
      background: #667eea;
      color: white;
    }

    .btn-primary:hover {
      background: #5568d3;
    }

    .btn-secondary {
      background: #95a5a6;
      color: white;
    }

    .btn-secondary:hover {
      background: #7f8c8d;
    }

    .btn-sm {
      padding: 8px 16px;
      font-size: 13px;
    }

    .alert {
      padding: 15px;
      border-radius: 5px;
      border-left: 4px solid;
    }

    .alert.success {
      background: #d1e7dd;
      color: #0f5132;
      border-color: #27ae60;
    }

    .alert.danger {
      background: #f8d7da;
      color: #842029;
      border-color: #e74c3c;
    }

    .info-section,
    .security-section,
    .stats-section {
      background: white;
      padding: 25px;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      margin-bottom: 30px;
    }

    .info-section h3,
    .security-section h3,
    .stats-section h3 {
      margin-top: 0;
      color: #2c3e50;
      border-bottom: 1px solid #ecf0f1;
      padding-bottom: 15px;
    }

    .info-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px;
      margin-top: 20px;
    }

    .info-item {
      display: flex;
      flex-direction: column;
    }

    .info-label {
      font-weight: 600;
      color: #666;
      font-size: 12px;
      text-transform: uppercase;
      margin-bottom: 8px;
    }

    .info-value {
      color: #2c3e50;
      font-size: 16px;
    }

    .security-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 20px;
      background: #f8f9fa;
      border-radius: 5px;
    }

    .security-item h4 {
      margin: 0 0 5px 0;
      color: #2c3e50;
    }

    .security-item p {
      margin: 0;
      color: #666;
      font-size: 14px;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 20px;
      margin-top: 20px;
    }

    .stat-item {
      background: #f8f9fa;
      padding: 20px;
      border-radius: 8px;
      text-align: center;
      border-top: 3px solid #667eea;
    }

    .stat-icon {
      font-size: 24px;
      display: block;
      margin-bottom: 10px;
    }

    .stat-label {
      display: block;
      color: #666;
      font-size: 12px;
      text-transform: uppercase;
      margin-bottom: 8px;
    }

    .stat-value {
      display: block;
      color: #2c3e50;
      font-size: 24px;
      font-weight: 700;
    }

    .alert.warning {
      background: #fef3c7;
      color: #92400e;
      padding: 12px 16px;
      border-radius: 6px;
      font-weight: 600;
    }

    @media (max-width: 768px) {
      .sidebar {
        display: none;
      }

      .perfil-card {
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 20px;
      }

      .form-actions {
        flex-direction: column;
      }

      .btn {
        width: 100%;
        text-align: center;
      }

      .security-item {
        flex-direction: column;
        align-items: flex-start;
      }
    }
  </style>
</head>

<body>

  <!-- ── Sidebar ── -->
  <aside class="sidebar">
    <a href="/" class="sidebar-brand">
      <img src="/img/logo.png" alt="Logo OPUS" />
      <span class="sidebar-brand-text">OPUS <em>Engenharia</em></span>
    </a>

    <div class="sidebar-section">
      <p class="sidebar-section-label">Menu</p>
      <a href="/colaborador/dashboard" class="nav-link">
        <i data-lucide="layout-dashboard"></i> Dashboard
      </a>
      <a href="/colaborador/clientes" class="nav-link">
        <i data-lucide="users"></i> Clientes
      </a>
      <a href="/colaborador/admin" class="nav-link">
        <i data-lucide="settings-2"></i> Administração
      </a>
      <a href="/colaborador/perfil" class="nav-link active">
        <i data-lucide="user"></i> Meu Perfil
      </a>
    </div>

    <div class="sidebar-spacer"></div>

    <div class="sidebar-footer">
      <a href="/logout" class="nav-link logout">
        <i data-lucide="log-out"></i> Sair
      </a>
    </div>
  </aside>

  <!-- ──Main ── -->

  <div class="main-content">
    <header class="topbar">
      <span class="topbar-title">Meu Perfil</span>
      <div class="topbar-user">
        <div class="user-avatar">
          <%= usuario.nome.charAt(0).toUpperCase() %>
        </div>
        <div class="user-details">
          <span class="user-name"><%= usuario.nome %></span>
          <span class="user-role"><%= usuario.tipo === 'admin' ? 'Administrador' : 'Colaborador' %></span>
        </div>
      </div>
    </header>

    <main class="page-content">
      <div class="perfil-card">
        <div class="perfil-avatar">
          <span class="avatar-icon">👤</span>
        </div>
        <div class="perfil-content">
          <h2><%= usuario.nome %></h2>
          <p class="perfil-type"><%= usuario.tipo === 'admin' ? 'Administrador' : 'Colaborador/Prestador' %></p>

          <% if (isAdminEnv) { %>
            <div class="alert warning" style="margin-bottom: 16px;">
              Perfil admin de backup. Alteracoes nao sao permitidas aqui.
            </div>
          <% } %>

          <form id="perfilForm" class="perfil-form" data-readonly="<%= isAdminEnv ? '1' : '0' %>">
            <div class="form-group">
              <label for="nome">Nome Completo:</label>
              <input
                type="text"
                id="nome"
                name="nome"
                value="<%= usuario.nome %>"
                class="form-control"
                required
                <%= isAdminEnv ? 'disabled' : '' %>
              >
            </div>

            <div class="form-group">
              <label for="email">Email:</label>
              <input
                type="email"
                id="email"
                value="<%= usuario.email %>"
                class="form-control"
                disabled
              >
              <small class="form-text">Email nao pode ser alterado</small>
            </div>

            <div class="form-group">
              <label for="telefone">Telefone:</label>
              <input
                type="tel"
                id="telefone"
                name="telefone"
                value="<%= usuario.telefone || '' %>"
                class="form-control"
                placeholder="(11) 9999-9999"
                <%= isAdminEnv ? 'disabled' : '' %>
              >
            </div>

            <div class="form-info">
              <p>
                <strong>Membro desde:</strong>
                <%= new Date(usuario.data_criacao).toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' }) %>
              </p>
              <p>
                <strong>Status:</strong>
                <span class="status-badge status-<%= usuario.ativo ? 'ativo' : 'inativo' %>">
                  <%= usuario.ativo ? 'Ativo' : 'Inativo' %>
                </span>
              </p>
            </div>

            <% if (!isAdminEnv) { %>
              <div class="form-actions">
                <button type="submit" class="btn btn-primary">Salvar Alteracoes</button>
                <button type="button" class="btn btn-secondary" onclick="location.reload()">Cancelar</button>
              </div>
            <% } %>

            <div id="messageContainer" style="display:none; margin-top: 20px;">
              <div id="message" class="alert"></div>
            </div>
          </form>
        </div>
      </div>

      <div class="info-section">
        <h3>Informacoes de Conta</h3>
        <div class="info-grid">
          <div class="info-item">
            <span class="info-label">ID da Conta:</span>
            <span class="info-value"><%= usuario.id %></span>
          </div>
          <div class="info-item">
            <span class="info-label">Tipo de Usuario:</span>
            <span class="info-value"><%= usuario.tipo === 'admin' ? 'Administrador' : 'Colaborador' %></span>
          </div>
          <div class="info-item">
            <span class="info-label">Data de Criacao:</span>
            <span class="info-value"><%= new Date(usuario.data_criacao).toLocaleDateString('pt-BR') %></span>
          </div>
        </div>
      </div>

      <div class="security-section">
        <h3>Seguranca</h3>
        <div class="security-item">
          <div>
            <h4>Alterar Senha</h4>
            <p>Para alterar sua senha, entre em contato com o administrador.</p>
          </div>
          <a href="/contato" class="btn btn-secondary btn-sm">Contatar Suporte</a>
        </div>
      </div>

      <div class="stats-section">
        <h3>Minhas Estatisticas</h3>
        <div class="stats-grid">
          <div class="stat-item">
            <span class="stat-icon">📦</span>
            <span class="stat-label">Servicos Gerenciados</span>
            <span class="stat-value">-</span>
          </div>
          <div class="stat-item">
            <span class="stat-icon">📋</span>
            <span class="stat-label">Laudos Criados</span>
            <span class="stat-value">-</span>
          </div>
          <div class="stat-item">
            <span class="stat-icon">✅</span>
            <span class="stat-label">Servicos Concluidos</span>
            <span class="stat-value">-</span>
          </div>
          <div class="stat-item">
            <span class="stat-icon">⭐</span>
            <span class="stat-label">Avaliacao</span>
            <span class="stat-value">-</span>
          </div>
        </div>
      </div>
    </main>
  </div>

  <script>
    // Inicializa os ícones Lucide
    if (typeof lucide !== 'undefined') {
      lucide.createIcons();
    }

    const perfilForm = document.getElementById('perfilForm');
    if (perfilForm.dataset.readonly === '1') {
      // Formulário read-only para admin-env, não adicionar event listener
    } else {
      // Adiciona listener para envio do formulário
      perfilForm.addEventListener('submit', function(e) {
        e.preventDefault();

        const formData = new FormData(this);
        const dados = {
          nome: formData.get('nome'),
          telefone: formData.get('telefone')
        };

        fetch('/colaborador/perfil/atualizar', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(dados)
        })
        .then(res => res.json())
        .then(data => {
          const messageContainer = document.getElementById('messageContainer');
          const message = document.getElementById('message');

          messageContainer.style.display = 'block';
          message.textContent = data.mensagem;
          message.className = 'alert ' + (data.sucesso ? 'success' : 'danger');

          if (data.sucesso) {
            setTimeout(() => {
              location.reload();
            }, 2000);
          }
        })
        .catch(err => {
          console.error('Erro:', err);
          alert('Erro ao atualizar perfil');
        });
      });
    }
  </script>
</body>

</html>
