<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login | OPUS Engenharia</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <script src="https://unpkg.com/lucide@latest"></script>
  <style>
    :root {
      --primary: #2563eb;
      --primary-dark: #1d4ed8;
      --secondary: #f97316;
      --gray-50: #f8fafc;
      --gray-100: #f1f5f9;
      --gray-200: #e2e8f0;
      --gray-400: #94a3b8;
      --gray-500: #64748b;
      --gray-600: #475569;
      --gray-700: #334155;
      --gray-900: #0f172a;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', sans-serif;
      height: 100vh;
      display: flex;
      overflow: hidden;
    }

    /* ── Painel Esquerdo (branding) ── */
    .login-brand {
      width: 45%;
      background: linear-gradient(145deg, var(--primary-dark) 0%, var(--primary) 60%, #3b82f6 100%);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 3rem;
      position: relative;
      overflow: hidden;
      color: white;
    }

    .login-brand::before {
      content: '';
      position: absolute;
      inset: 0;
      background: url('https://images.unsplash.com/photo-1581094794329-c8112c4e56a1?auto=format&fit=crop&q=60') center/cover no-repeat;
      opacity: 0.07;
    }

    .brand-top {
      position: relative;
      z-index: 1;
    }

    .brand-logo {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      text-decoration: none;
      color: white;
      margin-bottom: 3rem;
    }

    .brand-logo img {
      width: 42px;
      height: auto;
      filter: brightness(0) invert(1);
    }

    .brand-logo span {
      font-size: 1.5rem;
      font-weight: 800;
      letter-spacing: -0.5px;
    }

    .brand-logo span em {
      font-style: normal;
      color: var(--secondary);
    }

    .brand-headline {
      position: relative;
      z-index: 1;
    }

    .brand-headline h1 {
      font-size: 2.25rem;
      font-weight: 800;
      line-height: 1.2;
      margin-bottom: 1rem;
    }

    .brand-headline p {
      font-size: 1rem;
      color: rgba(255, 255, 255, 0.75);
      line-height: 1.7;
      max-width: 340px;
    }

    .brand-badges {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .brand-badge {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      background: rgba(255, 255, 255, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: 0.75rem;
      padding: 0.75rem 1rem;
      backdrop-filter: blur(8px);
      font-size: 0.875rem;
      font-weight: 500;
    }

    .brand-badge i {
      width: 18px;
      height: 18px;
      color: var(--secondary);
      flex-shrink: 0;
    }

    /* ── Painel Direito (formulário) ── */
    .login-form-side {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      background: var(--gray-50);
      padding: 2rem;
      overflow-y: auto;
    }

    .login-card {
      width: 100%;
      max-width: 420px;
    }

    .login-card-header {
      margin-bottom: 2rem;
    }

    .login-card-header h2 {
      font-size: 1.75rem;
      font-weight: 800;
      color: var(--gray-900);
      margin-bottom: 0.375rem;
    }

    .login-card-header p {
      color: var(--gray-500);
      font-size: 0.9375rem;
    }

    /* Alerta de erro */
    .alert-error {
      display: flex;
      align-items: center;
      gap: 0.625rem;
      background: #fef2f2;
      border: 1px solid #fecaca;
      border-left: 4px solid #ef4444;
      border-radius: 0.5rem;
      padding: 0.875rem 1rem;
      margin-bottom: 1.5rem;
      color: #b91c1c;
      font-size: 0.875rem;
    }

    .alert-error i {
      width: 18px;
      height: 18px;
      flex-shrink: 0;
    }

    /* Campos */
    .form-group {
      margin-bottom: 1.25rem;
    }

    .form-group label {
      display: block;
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--gray-700);
      margin-bottom: 0.5rem;
    }

    .input-wrap {
      position: relative;
    }

    .input-wrap i,
    .input-wrap svg {
      position: absolute;
      left: 0.875rem;
      top: 50%;
      transform: translateY(-50%);
      width: 18px;
      height: 18px;
      color: var(--gray-400);
      pointer-events: none;
      display: block;
    }

    .form-control {
      width: 100%;
      padding: 0.75rem 0.875rem 0.75rem 2.625rem;
      border: 1.5px solid var(--gray-200);
      border-radius: 0.625rem;
      font-size: 0.9375rem;
      font-family: 'Inter', sans-serif;
      color: var(--gray-700);
      background: white;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    .form-control:focus {
      outline: none;
      border-color: var(--primary);
      box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
    }

    select.form-control {
      appearance: none;
      cursor: pointer;
    }

    /* Botão */
    .btn-login {
      width: 100%;
      padding: 0.875rem;
      background: var(--primary);
      color: white;
      border: none;
      border-radius: 0.625rem;
      font-size: 1rem;
      font-weight: 700;
      font-family: 'Inter', sans-serif;
      cursor: pointer;
      transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
      margin-top: 0.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
    }

    .btn-login:hover {
      background: var(--primary-dark);
      transform: translateY(-1px);
      box-shadow: 0 6px 20px rgba(37, 99, 235, 0.35);
    }

    .btn-login:active {
      transform: translateY(0);
    }

    .btn-login i {
      width: 18px;
      height: 18px;
    }

    /* Rodapé do card */
    .form-footer {
      margin-top: 1.75rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--gray-200);
      text-align: center;
    }

    .form-footer p {
      font-size: 0.875rem;
      color: var(--gray-500);
    }

    .form-footer a {
      color: var(--primary);
      font-weight: 600;
      text-decoration: none;
      transition: color 0.2s;
    }

    .form-footer a:hover {
      color: var(--primary-dark);
      text-decoration: underline;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.375rem;
      color: var(--gray-500);
      font-size: 0.875rem;
      text-decoration: none;
      margin-bottom: 2rem;
      transition: color 0.2s;
    }

    .back-link:hover {
      color: var(--primary);
    }

    .back-link i {
      width: 16px;
      height: 16px;
    }

    /* ── Responsivo ── */
    @media (max-width: 768px) {
      body {
        flex-direction: column;
        height: auto;
        overflow: auto;
      }

      .login-brand {
        width: 100%;
        padding: 2rem 1.5rem;
        min-height: 220px;
      }

      .brand-headline h1 {
        font-size: 1.5rem;
      }

      .brand-headline p {
        display: none;
      }

      .brand-badges {
        display: none;
      }

      .login-form-side {
        padding: 2rem 1.25rem;
        min-height: 100vh;
      }
    }
  </style>
</head>

<body>

  <%- include('../partials/whatsapp-float') %>

  <!-- Painel de Branding -->
  <div class="login-brand">
    <div class="brand-top">
      <a href="/" class="brand-logo">
        <img src="/img/logo.png" alt="Logo OPUS">
        <span>OPUS <em>Engenharia</em></span>
      </a>
    </div>

    <div class="brand-headline">
      <h1>Acesse sua área exclusiva</h1>
      <p>Acompanhe seus projetos, laudos e documentos técnicos em tempo real, com segurança e praticidade.</p>
    </div>

    <div class="brand-badges">
      <div class="brand-badge">
        <i data-lucide="shield-check"></i>
        Ambiente seguro e criptografado
      </div>
      <div class="brand-badge">
        <i data-lucide="file-check-2"></i>
        Documentos e laudos centralizados
      </div>
      <div class="brand-badge">
        <i data-lucide="clock"></i>
        Acompanhe o status em tempo real
      </div>
    </div>
  </div>

  <!-- Painel do Formulário -->
  <div class="login-form-side">
    <div class="login-card">

      <a href="/" class="back-link">
        <i data-lucide="arrow-left"></i>
        Voltar ao site
      </a>

      <div class="login-card-header">
        <h2>Bem-vindo de volta</h2>
        <p>Faça login para acessar seu painel</p>
      </div>

      <% if (erro) { %>
        <div class="alert-error">
          <i data-lucide="alert-circle"></i>
          <%= erro %>
        </div>
        <% } %>

          <form action="/login" method="POST" id="loginForm">

            <div class="form-group">
              <label for="tipo">Você é:</label>
              <div class="input-wrap">
                <i data-lucide="users"></i>
                <select class="form-control" id="tipo" name="tipo" required>
                  <option value="">Selecione seu perfil...</option>
                  <option value="cliente">Cliente</option>
                  <option value="colaborador">Colaborador / Prestador</option>
                </select>
              </div>
            </div>

            <div class="form-group">
              <label for="email">E-mail</label>
              <div class="input-wrap">
                <i data-lucide="mail"></i>
                <input type="email" class="form-control" id="email" name="email" required placeholder="seu@email.com" />
              </div>
            </div>

            <div class="form-group">
              <label for="senha">Senha</label>
              <div class="input-wrap">
                <i data-lucide="lock"></i>
                <input type="password" class="form-control" id="senha" name="senha" required placeholder="••••••••" />
              </div>
            </div>

            <button type="submit" class="btn-login">
              <i data-lucide="log-in"></i>
              Entrar
            </button>
          </form>

          <div class="form-footer">
            <p>Não tem acesso? <a href="/registro">Cadastre-se aqui</a></p>
          </div>

    </div>
  </div>

  <script>lucide.createIcons();</script>
</body>

</html>