<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Detalhes do Servico | OPUS Engenharia</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/painel.css" />
  <script src="https://unpkg.com/lucide@latest"></script>
  <style>
    .back-link {
      display: inline-block;
      color: #3498db;
      text-decoration: none;
      font-weight: 600;
      margin-bottom: 10px;
    }

    .service-detail-card {
      background: white;
      margin-bottom: 40px;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      overflow: hidden;
    }

    .card-header {
      background: #f8f9fa;
      padding: 20px;
      border-bottom: 1px solid #ecf0f1;
    }

    .card-header h2 {
      margin: 0;
      color: #2c3e50;
      font-size: 18px;
    }

    .card-body {
      padding: 25px;
    }

    .status-info {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
      margin-bottom: 30px;
    }

    .info-group {
      display: flex;
      flex-direction: column;
    }

    .info-group label {
      font-weight: 600;
      color: #666;
      margin-bottom: 8px;
      font-size: 12px;
      text-transform: uppercase;
    }

    .info-group span {
      color: #2c3e50;
      font-size: 16px;
    }

    .status-badge {
      display: inline-block;
      padding: 6px 12px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
      width: fit-content;
    }

    .status-pendente {
      background: #fff3cd;
      color: #856404;
    }

    .status-em_andamento {
      background: #cfe2ff;
      color: #084298;
    }

    .status-concluido {
      background: #d1e7dd;
      color: #0f5132;
    }

    .priority {
      display: inline-block;
      padding: 6px 12px;
      border-radius: 4px;
      font-size: 12px;
      font-weight: 600;
      width: fit-content;
    }

    .priority-baixa {
      background: #e8f4f8;
      color: #0c5460;
    }

    .priority-normal {
      background: #fff3cd;
      color: #856404;
    }

    .priority-alta {
      background: #f8d7da;
      color: #721c24;
    }

    .progress-wrapper {
      margin-top: 20px;
    }

    .progress-bar {
      height: 8px;
      background: #ecf0f1;
      border-radius: 4px;
      overflow: hidden;
    }

    .progress {
      height: 100%;
      background: linear-gradient(90deg, #27ae60, #2ecc71);
      transition: width 0.3s;
    }

    .progress-label {
      margin-top: 8px;
      font-size: 12px;
      color: #7f8c8d;
    }

    .empty-message {
      text-align: center;
      color: #95a5a6;
      padding: 30px 0;
      margin: 0;
    }

    .updates-list {
      display: flex;
      flex-direction: column;
      gap: 15px;
    }

    .update-item {
      padding: 15px;
      background: #f8f9fa;
      border-radius: 6px;
      border-left: 3px solid #3498db;
    }

    .update-header {
      display: flex;
      justify-content: space-between;
      margin-bottom: 10px;
    }

    .update-author {
      font-weight: 600;
      color: #2c3e50;
    }

    .update-date {
      font-size: 12px;
      color: #95a5a6;
    }

    .update-message {
      margin: 0;
      color: #555;
      line-height: 1.5;
    }

    .laudos-list {
      display: flex;
      flex-direction: column;
      gap: 15px;
    }

    .laudo-item {
      padding: 20px;
      background: #f8f9fa;
      border-radius: 6px;
      border-left: 3px solid #9b59b6;
    }

    .laudo-header {
      display: flex;
      justify-content: space-between;
      align-items: start;
      margin-bottom: 10px;
    }

    .laudo-header h3 {
      margin: 0;
      color: #2c3e50;
    }

    .laudo-status {
      padding: 4px 10px;
      border-radius: 4px;
      font-size: 11px;
      font-weight: 600;
    }

    .laudo-rascunho {
      background: #fff3cd;
      color: #856404;
    }

    .laudo-enviado {
      background: #cfe2ff;
      color: #084298;
    }

    .laudo-assinado {
      background: #d1e7dd;
      color: #0f5132;
    }

    .laudo-preview {
      color: #555;
      font-size: 14px;
      margin: 10px 0;
      line-height: 1.5;
    }

    .laudo-meta {
      display: flex;
      gap: 20px;
      font-size: 12px;
      color: #95a5a6;
      margin: 10px 0;
    }

    .laudo-info {
      margin: 10px 0 0 0;
      font-size: 12px;
      color: #27ae60;
      font-weight: 500;
    }

    @media (max-width: 768px) {
      .sidebar {
        display: none;
      }

      .status-info {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>

<body>
  <aside class="sidebar">
    <a href="/" class="sidebar-brand">
      <img src="/img/logo.png" alt="Logo OPUS" />
      <span class="sidebar-brand-text">OPUS <em>Engenharia</em></span>
    </a>

    <div class="sidebar-section">
      <p class="sidebar-section-label">Menu</p>
      <a href="/cliente/dashboard" class="nav-link">
        <i data-lucide="layout-dashboard"></i> Dashboard
      </a>
      <a href="/cliente/laudos" class="nav-link active">
        <i data-lucide="file-text"></i> Laudos Tecnicos
      </a>
      <a href="/cliente/perfil" class="nav-link">
        <i data-lucide="user"></i> Meu Perfil
      </a>
    </div>

    <div class="sidebar-spacer"></div>

    <div class="sidebar-footer">
      <a href="/logout" class="nav-link logout">
        <i data-lucide="log-out"></i> Sair
      </a>
    </div>
  </aside>

  <div class="main-content">
    <header class="topbar">
      <span class="topbar-title">Detalhes do Servico</span>
      <div class="topbar-user">
        <div class="user-avatar">
          <%= usuario.nome.charAt(0).toUpperCase() %>
        </div>
        <div class="user-details">
          <span class="user-name"><%= usuario.nome %></span>
          <span class="user-role">Cliente</span>
        </div>
      </div>
    </header>

    <main class="page-content">
      <a href="/cliente/dashboard" class="back-link">← Voltar</a>
      <h1><%= servico.titulo %></h1>

      <div class="service-detail-card">
        <div class="card-header">
          <h2>Status do Servico</h2>
        </div>
        <div class="card-body">
          <div class="status-info">
            <div class="info-group">
              <label>Status:</label>
              <span class="status-badge status-<%= servico.status %>">
                <%= servico.status.replace(/_/g, ' ').toUpperCase() %>
              </span>
            </div>
            <div class="info-group">
              <label>Prioridade:</label>
              <span class="priority priority-<%= servico.prioridade %>">
                <%= servico.prioridade.toUpperCase() %>
              </span>
            </div>
            <div class="info-group">
              <label>Data de Criacao:</label>
              <span><%= new Date(servico.data_criacao).toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
            </div>
            <% if (servico.data_conclusao) { %>
              <div class="info-group">
                <label>Data de Conclusao:</label>
                <span><%= new Date(servico.data_conclusao).toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit', year: 'numeric' }) %></span>
              </div>
            <% } %>
          </div>

          <div class="progress-wrapper">
            <div class="progress-bar">
              <div class="progress" data-progress="<%= servico.status === 'concluido' ? 100 : servico.status === 'em_andamento' ? 50 : servico.status === 'pendente' ? 25 : 75 %>"></div>
            </div>
            <div class="progress-label">
              <%= servico.status === 'concluido' ? 'Concluido' : servico.status === 'em_andamento' ? 'Em Andamento' : servico.status === 'pendente' ? 'Pendente' : 'Cancelado' %>
            </div>
          </div>
        </div>
      </div>

      <div class="service-detail-card">
        <div class="card-header">
          <h2>Descricao</h2>
        </div>
        <div class="card-body">
          <p><%= servico.descricao || 'Sem descricao adicional' %></p>
        </div>
      </div>

      <div class="service-detail-card">
        <div class="card-header">
          <h2>Atualizacoes do Status</h2>
        </div>
        <div class="card-body">
          <% if (atualizacoes.length === 0) { %>
            <p class="empty-message">Nenhuma atualizacao disponivel</p>
          <% } else { %>
            <div class="updates-list">
              <% atualizacoes.forEach(atualizacao => { %>
                <div class="update-item">
                  <div class="update-header">
                    <span class="update-author"><%= atualizacao.colaborador_nome || 'Sistema' %></span>
                    <span class="update-date"><%= new Date(atualizacao.data_criacao).toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
                  </div>
                  <p class="update-message"><%= atualizacao.mensagem %></p>
                </div>
              <% }); %>
            </div>
          <% } %>
        </div>
      </div>

      <div class="service-detail-card">
        <div class="card-header">
          <h2>Laudos Tecnicos</h2>
        </div>
        <div class="card-body">
          <% if (laudos.length === 0) { %>
            <p class="empty-message">Nenhum laudo disponivel</p>
          <% } else { %>
            <div class="laudos-list">
              <% laudos.forEach(laudo => { %>
                <div class="laudo-item">
                  <div class="laudo-header">
                    <h3><%= laudo.titulo %></h3>
                    <span class="laudo-status laudo-<%= laudo.status %>">
                      <%= laudo.status.toUpperCase() %>
                    </span>
                  </div>
                  <p class="laudo-preview"><%= laudo.conteudo.substring(0, 200) %>...</p>
                  <div class="laudo-meta">
                    <span class="laudo-creator">Por: <%= laudo.criador_nome || 'Sistema' %></span>
                    <span class="laudo-date"><%= new Date(laudo.data_criacao).toLocaleDateString('pt-BR') %></span>
                  </div>
                  <% if (laudo.data_envio) { %>
                    <p class="laudo-info">Enviado em: <%= new Date(laudo.data_envio).toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></p>
                  <% } %>
                </div>
              <% }); %>
            </div>
          <% } %>
        </div>
      </div>
    </main>
  </div>

  <script>
    lucide.createIcons();

    (function() {
      const progress = document.querySelector('.progress');
      if (!progress) return;
      const value = Number(progress.dataset.progress || 0);
      progress.style.width = `${Math.min(100, Math.max(0, value))}%`;
    })();
  </script>
</body>

</html>
