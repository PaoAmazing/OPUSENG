<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard | OPUS Engenharia</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/painel.css" />
  <script src="https://unpkg.com/lucide@latest"></script>
</head>

<body>

  <!-- ── Sidebar ── -->
  <aside class="sidebar">
    <a href="/" class="sidebar-brand">
      <img src="/img/logo.png" alt="Logo OPUS" />
      <span class="sidebar-brand-text">OPUS <em>Engenharia</em></span>
    </a>

    <div class="sidebar-section">
      <p class="sidebar-section-label">Menu</p>
      <a href="/cliente/dashboard" class="nav-link active">
        <i data-lucide="layout-dashboard"></i> Dashboard
      </a>
      <a href="/cliente/laudos" class="nav-link">
        <i data-lucide="file-text"></i> Laudos Técnicos
      </a>
      <a href="/cliente/perfil" class="nav-link">
        <i data-lucide="user"></i> Meu Perfil
      </a>
    </div>

    <div class="sidebar-spacer"></div>

    <div class="sidebar-footer">
      <a href="/logout" class="nav-link logout">
        <i data-lucide="log-out"></i> Sair
      </a>
    </div>
  </aside>

  <!-- ── Main ── -->
  <div class="main-content">

    <!-- Topbar -->
    <header class="topbar">
      <span class="topbar-title">Dashboard do Cliente</span>
      <div class="topbar-user">
        <div class="user-avatar">
          <%= usuario.nome.charAt(0).toUpperCase() %>
        </div>
        <div class="user-details">
          <span class="user-name">
            <%= usuario.nome %>
          </span>
          <span class="user-role">Cliente</span>
        </div>
      </div>
    </header>

    <!-- Conteúdo -->
    <main class="page-content">

      <!-- Stat Cards -->
      <div class="stats-grid">
        <div class="stat-card total">
          <div class="stat-icon"><i data-lucide="package"></i></div>
          <div>
            <div class="stat-value">
              <%= contadores.total %>
            </div>
            <div class="stat-label">Total de Serviços</div>
          </div>
        </div>
        <div class="stat-card pending">
          <div class="stat-icon"><i data-lucide="clock"></i></div>
          <div>
            <div class="stat-value">
              <%= contadores.pendente %>
            </div>
            <div class="stat-label">Pendentes</div>
          </div>
        </div>
        <div class="stat-card ongoing">
          <div class="stat-icon"><i data-lucide="refresh-cw"></i></div>
          <div>
            <div class="stat-value">
              <%= contadores.em_andamento %>
            </div>
            <div class="stat-label">Em Andamento</div>
          </div>
        </div>
        <div class="stat-card done">
          <div class="stat-icon"><i data-lucide="check-circle-2"></i></div>
          <div>
            <div class="stat-value">
              <%= contadores.concluido %>
            </div>
            <div class="stat-label">Concluídos</div>
          </div>
        </div>
      </div>

      <!-- Serviços -->
      <div class="card">
        <div class="card-header">
          <h2 class="card-title">Meus Serviços</h2>
          <a href="/contato" class="btn btn-primary btn-sm">
            <i data-lucide="plus"></i> Solicitar Serviço
          </a>
        </div>

        <% if (servicos.length===0) { %>
          <div class="empty-state">
            <i data-lucide="inbox"></i>
            <p>Você ainda não possui serviços.</p>
            <a href="/contato" class="btn btn-primary">Entre em Contato</a>
          </div>
          <% } else { %>
            <div class="card-body">
              <div class="services-grid-cards">
                <% servicos.forEach(servico=> { %>
                  <div class="service-card-item">
                    <div
                      style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:0.5rem;">
                      <h3>
                        <%= servico.titulo %>
                      </h3>
                      <span class="badge badge-<%= servico.status %>">
                        <%= servico.status.replace(/_/g,' ').replace(/\b\w/g,c=>c.toUpperCase()) %>
                    </span>
                  </div>
                  <p><%= servico.descricao || ' Sem descrição disponível.' %>
                          </p>
                          <div class="service-meta-info">
                            <span class="badge badge-prioridade-<%= servico.prioridade %>">
                              <%= servico.prioridade.toUpperCase() %>
                            </span>
                            <span class="date-label">
                              <%= new Date(servico.data_criacao).toLocaleDateString('pt-BR') %>
                            </span>
                          </div>
                          <div class="service-card-footer">
                            <a href="/cliente/servico/<%= servico.id %>" class="btn btn-outline btn-sm">
                              <i data-lucide="eye"></i> Ver Detalhes
                            </a>
                          </div>
                    </div>
                    <% }); %>
                  </div>
              </div>
              <% } %>
            </div>

    </main>
  </div>

  <script>lucide.createIcons();</script>
</body>

</html>